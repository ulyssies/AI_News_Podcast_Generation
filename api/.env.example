# Copy to .env and fill in your keys:
# cp .env.example .env

# Required for script generation and TTS (audio)
OPENAI_API_KEY=sk-...

# Optional: override models
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=alloy

# Optional: richer news (get free key at https://newsapi.org)
# NEWS_API_KEY=...
