# Copy to .env and fill in your keys:
# cp .env.example .env

# Required for TTS (audio). Still needed for full episodes.
OPENAI_API_KEY=sk-...

# Script generation: set this to use Claude instead of OpenAI for the podcast script.
# If unset, script uses OPENAI_API_KEY (same model as before).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional (only when not using Anthropic for script)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TTS_MODEL=tts-1        <- default, fast; tts-1-hd = better quality, much slower
# OPENAI_TTS_VOICE=alloy

# Optional: richer news (get free key at https://newsapi.org)
# NEWS_API_KEY=...
